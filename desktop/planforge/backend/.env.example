# PlanForge backend — copy to .env and adjust. All vars use the PLANFORGE_ prefix.

# --- Database (SQLite for dev; Postgres in prod) ---
PLANFORGE_DATABASE_URL=sqlite:///./planforge.db

# --- Auth ---
PLANFORGE_JWT_SECRET=change-me-in-prod
PLANFORGE_ACCESS_TOKEN_MINUTES=15
PLANFORGE_REFRESH_TOKEN_DAYS=14

# --- Dispatch ---
# true = run generation in-process (no Redis/worker). false = Redis queue + worker.
PLANFORGE_INLINE_DISPATCH=false

# --- Redis ---
PLANFORGE_REDIS_URL=redis://localhost:6379/0
PLANFORGE_JOB_QUEUE_NAME=planforge:jobs

# --- Progress events (SSE) ---
PLANFORGE_JOB_EVENT_TTL_SECONDS=3600
PLANFORGE_SSE_POLL_INTERVAL_SECONDS=0.5
PLANFORGE_SSE_MAX_SECONDS=120

# --- Rate limiting ---
PLANFORGE_GENERATE_RATE_LIMIT_PER_MINUTE=10
PLANFORGE_RATE_LIMIT_WINDOW_SECONDS=60

# --- LLM ---
# provider: ollama (local, no key) | anthropic (cloud key) | fake (stub).
# Seeds the runtime settings store; the desktop app overrides at runtime.
# Anthropic selected without a key falls back to "fake".
PLANFORGE_LLM_PROVIDER=anthropic
PLANFORGE_ANTHROPIC_API_KEY=
PLANFORGE_LLM_MODEL=claude-sonnet-4-6
PLANFORGE_LLM_TEMPERATURE=0.4
PLANFORGE_LLM_MAX_TOKENS=8192

# Ollama (local LLM — no API key, runs on the user's machine)
PLANFORGE_OLLAMA_BASE_URL=http://localhost:11434
PLANFORGE_OLLAMA_MODEL=llama3.1

# --- Prompts (defaults to ../prompts; usually leave unset) ---
# PLANFORGE_PROMPTS_DIR=/abs/path/to/planforge/prompts
