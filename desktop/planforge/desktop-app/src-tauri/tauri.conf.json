{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PlanForge",
  "version": "0.1.0",
  "identifier": "com.planforge.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PlanForge",
        "width": 1100,
        "height": 760,
        "minWidth": 820,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' http://localhost:8000 http://localhost:11434",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/planforge-backend"],
    "macOS": {
      "hardenedRuntime": true
    }
  }
}
