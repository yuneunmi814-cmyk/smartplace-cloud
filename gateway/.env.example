# Gateway config (prefix GATEWAY_).

# Shared secret the cloud worker uses as Authorization: Bearer.
# Must equal SMARTPLACE_NAVER_GATEWAY_KEY on the backend/worker side.
GATEWAY_KEY=change-me-to-a-long-random-string

# MOCK=1 returns success without a browser (wiring/CI). Set 0 for real Naver.
GATEWAY_MOCK=1

# Real-automation knobs (used when GATEWAY_MOCK=0):
GATEWAY_HEADLESS=true
GATEWAY_SESSION_TTL_SECONDS=1800
